@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutLogin";
}

<script>
    window.history.pushState(null, null, window.location.href);
    window.onpopstate = function () {
        history.go(1);
    };
</script>

<style>
    .login-split-shell {
        min-height: calc(100vh - 11rem);
        font-family: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        margin-top: 0.9rem;
    }

    .login-split-row {
        min-height: calc(100vh - 11rem);
    }

    .login-brand-panel {
        position: relative;
        overflow: hidden;
        background: linear-gradient(155deg, #1e293b 0%, #0f172a 50%, #172554 100%);
        color: #e2e8f0;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 2.5rem 2rem;
        text-align: center;
    }

    .login-brand-panel::before {
        content: "";
        position: absolute;
        inset: 0;
        background: url("@Url.Content("~/images/logo.png")") center 42% / min(320px, 55%) no-repeat;
        opacity: 0.04;
        pointer-events: none;
    }

    .login-brand-panel::after {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 50% at 50% 100%, rgba(59, 130, 246, 0.1), transparent 55%);
        pointer-events: none;
    }

    .login-brand-inner {
        position: relative;
        z-index: 1;
        max-width: 22rem;
    }

    .login-brand-logo {
        max-height: 10rem;
        width: auto;
        filter: brightness(0) invert(1);
        opacity: 0.92;
    }

    .login-brand-title {
        font-size: 1.5rem;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: #d4af37;
        margin-top: 1.5rem;
    }

    .login-brand-line {
        width: 2.5rem;
        height: 2px;
        background: rgba(148, 163, 184, 0.45);
        margin: 1rem auto 0;
        border-radius: 1px;
    }

    .login-brand-tag {
        font-size: 0.875rem;
        color: #d4af37;
        margin-top: 1rem;
        line-height: 1.5;
        font-weight: 500;
    }

    .login-form-panel {
        background: linear-gradient(180deg, #e2e8f0 0%, #f1f5f9 45%, #f8fafc 100%);
        padding-left: 1rem;
        padding-right: 1rem;
    }

    .login-glass-card {
        width: 100%;
        max-width: 26rem;
        padding: 2rem 1.75rem;
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.7);
        box-shadow:
            0 4px 24px rgba(15, 23, 42, 0.06),
            inset 0 1px 0 rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
    }

    @@supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) {
        .login-glass-card {
            background: rgba(255, 255, 255, 0.94);
        }
    }

    .login-mobile-brand {
        text-align: center;
        margin-bottom: 1.25rem;
    }

    .login-mobile-brand img {
        max-height: 2.5rem;
        width: auto;
    }

    .login-heading {
        font-size: 1.25rem;
        font-weight: 600;
        color: #0f172a;
        letter-spacing: -0.02em;
    }

    .login-sub {
        font-size: 0.8125rem;
        color: #64748b;
    }

    .login-input-group .input-group-text {
        background: rgba(248, 250, 252, 0.9);
        border-color: rgba(226, 232, 240, 0.95);
        color: #64748b;
        padding-left: 0.9rem;
        padding-right: 0.75rem;
    }

    .login-input-group .form-control {
        background: rgba(255, 255, 255, 0.75);
        border-color: rgba(226, 232, 240, 0.95);
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
        border-radius: 0 0.5rem 0.5rem 0;
    }

    .login-input-group .input-group-text {
        border-radius: 0.5rem 0 0 0.5rem;
    }

    .login-input-group .form-control:focus {
        border-color: #64748b;
        box-shadow: 0 0 0 0.2rem rgba(100, 116, 139, 0.2);
        background: #fff;
    }

    .login-input-group:focus-within .input-group-text {
        border-color: #94a3b8;
        background: #fff;
        color: #475569;
    }

    .login-btn-primary {
        font-weight: 600;
        letter-spacing: 0.02em;
        padding-top: 0.7rem;
        padding-bottom: 0.7rem;
        border-radius: 0.5rem;
        background: #334155;
        border: none;
        color: #fff;
        transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    }

    .login-btn-primary:hover {
        background: #1e293b;
        color: #fff;
        box-shadow: 0 6px 20px rgba(15, 23, 42, 0.12);
        transform: translateY(-1px);
    }

    .login-btn-primary:active {
        transform: translateY(0);
    }

    .login-forgot-link {
        font-size: 0.875rem;
        color: #475569;
        text-decoration: none;
    }

    .login-forgot-link:hover {
        color: #0f172a;
        text-decoration: underline;
    }

    .login-icon-svg {
        width: 1.1rem;
        height: 1.1rem;
        display: block;
    }

    .login-anim {
        opacity: 0;
        animation: loginFadeInUp 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    }

    .login-anim-brand {
        animation-delay: 0.06s;
    }

    .login-anim-form {
        animation-delay: 0.16s;
    }

    @@keyframes loginFadeInUp {
        from {
            opacity: 0;
            transform: translateY(14px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .login-anim {
            animation: none;
            opacity: 1;
            transform: none;
        }
    }
</style>

<div class="login-split-shell container-fluid px-0">
    <div class="row g-0 login-split-row">
        <div class="col-lg-6 login-brand-panel login-anim login-anim-brand d-none d-lg-flex">
            <div class="login-brand-inner">
                <img src="~/images/logo.png" alt="" class="login-brand-logo" asp-append-version="true" />
                <div class="login-brand-title">Billing System</div>
                <div class="login-brand-line"></div>
                <p class="login-brand-tag mb-0">Property of Bahria Town. Authorized users only. All system activities are monitored.</p>
            </div>
        </div>
        <div class="col-12 col-lg-6 login-form-panel d-flex align-items-center justify-content-center py-4 py-lg-5">
            <div class="login-glass-card login-anim login-anim-form">
                <div class="login-mobile-brand d-lg-none">
                    <img src="~/images/logo.png" alt="Logo" asp-append-version="true" />
                </div>
                <div class="text-center mb-4">
                    <h1 class="login-heading mb-1">Sign in</h1>
                    <p class="login-sub mb-0">Use your account credentials</p>
                </div>

                <form method="post" asp-controller="Login" asp-action="Index" novalidate>
                    <div class="mb-3">
                        <label for="username" class="form-label small fw-semibold text-secondary">Username</label>
                        <div class="input-group login-input-group rounded-3 overflow-hidden shadow-sm">
                            <span class="input-group-text border-end-0" aria-hidden="true">
                                <svg class="login-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            </span>
                            <input type="text" class="form-control border-start-0" id="username" name="username" required autocomplete="username" placeholder="Username" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label small fw-semibold text-secondary">Password</label>
                        <div class="input-group login-input-group rounded-3 overflow-hidden shadow-sm">
                            <span class="input-group-text border-end-0" aria-hidden="true">
                                <svg class="login-icon-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                            </span>
                            <input type="password" class="form-control border-start-0" id="password" name="password" required autocomplete="current-password" placeholder="Password" />
                        </div>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger py-2 small mb-3" role="alert">@ViewBag.Error</div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" value="true" id="rememberMe" name="rememberMe" />
                            <label class="form-check-label small text-secondary" for="rememberMe">Remember me</label>
                        </div>
                        <a href="#" class="login-forgot-link">Forgot password?</a>
                    </div>

                    <button type="submit" class="btn login-btn-primary w-100">Login</button>
                </form>
            </div>
        </div>
    </div>
</div>

