@using BMSBT.DTO
@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<MaintenanceBillDTO>

@{
    ViewData["Title"] = "All Bills";
    Layout = "~/Views/Shared/_LayoutMaintBills.cshtml";
    var bills = Model ?? new StaticPagedList<MaintenanceBillDTO>(new List<MaintenanceBillDTO>(), 1, 10000, 0);
    var groupedByProject = bills.GroupBy(b => b.Project)
        .Select(projGroup => new
        {
            Project = projGroup.Key,
            Blocks = projGroup.GroupBy(b => b.Block).OrderBy(bg => bg.Key)
        });
}

<div id="loadingOverlay" class="loading-overlay" style="display: none;">
    <div class="loading-spinner"></div>
    <div class="loading-text">Printing Bills...</div>
</div>

<style>
    /* Loading overlay */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .loading-spinner {
        width: 50px;
        height: 50px;
        border: 5px solid #f3f3f3;
        border-radius: 50%;
        border-top: 5px solid #3498db;
        animation: spin 1s linear infinite;
    }

    .loading-text {
        color: white;
        margin-top: 20px;
        font-size: 18px;
        font-weight: bold;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* Shell — aligned with CustomersMaintenance/Details.cshtml */
    .cm-detail-page {
        --cm-surface: #ffffff;
        --cm-heading: #0f172a;
        --cm-border: #e2e8f0;
        --cm-row-odd: #fafbfc;
        --cm-row-even: #ffffff;
        --cm-row-hover: #eef6ff;
        --cm-accent-soft: #e8f4fc;
        font-size: 0.9375rem;
        line-height: 1.45;
        color: #334155;
        padding-top: 0.35rem;
        padding-bottom: 1rem;
    }

    .cm-detail-card {
        background: var(--cm-surface);
        border: 1px solid var(--cm-border);
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        margin-bottom: 0.75rem;
    }

    .cm-detail-card .card-header {
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        border-bottom: 1px solid var(--cm-border);
        padding: 0.5rem 1rem;
    }

    .cm-detail-card .card-header .cm-header-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--cm-heading);
        margin: 0;
    }

    .cm-badge-soft {
        display: inline-block;
        padding: 0.12rem 0.45rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #e8f1ff;
        color: #1e40af;
        vertical-align: middle;
    }

    .cm-detail-card .card-body.cm-filter-body {
        padding: 1rem 1.25rem;
    }

    .cm-filter-body .form-control {
        border-radius: 6px;
        font-size: 0.875rem;
    }

    .cm-filter-body .btn {
        border-radius: 6px;
        font-weight: 500;
    }

    .cm-table-wrap {
        border-radius: 6px;
        border: 1px solid var(--cm-border);
        overflow: hidden;
        margin: 0.5rem 0.75rem 0.75rem;
    }

    .cm-detail-table.cm-search-bill-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
    }

    .cm-detail-table.cm-search-bill-table > thead > tr > th {
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.65rem 0.5rem;
        border-bottom: 1px solid var(--cm-border);
        vertical-align: middle;
    }

    .cm-search-summary {
        padding: 0.65rem 1.25rem;
        background: #f8fafc;
        border-bottom: 1px solid var(--cm-border);
        font-size: 0.875rem;
    }

    .nested-table {
        width: 100%;
        margin-bottom: 0;
    }

    .toggle-icon {
        transition: transform 0.3s;
    }

    .rotate-icon {
        transform: rotate(90deg);
    }

    .project-header {
        background-color: var(--cm-accent-soft) !important;
        cursor: pointer;
        padding-left: 10px;
    }

    .project-blocks {
        padding-left: 0;
    }

    .project-blocks > .nested-table {
        margin-left: 30px;
        padding-left: 0;
    }

    .block-header {
        background-color: #f8fafc !important;
        cursor: pointer;
        padding-left: 10px;
    }

    .block-content {
        padding-left: 30px;
        margin-left: 0;
    }

    .block-content > .nested-table {
        margin-left: 0;
    }

    .category-header {
        background-color: #f1f5f9 !important;
        cursor: pointer;
        padding-left: 10px;
    }

    .category-content {
        padding-left: 30px;
        margin-left: 0;
    }

    .category-content > .nested-table {
        margin-left: 0;
    }

    .customer-row {
        padding-left: 0;
    }

    .customer-row:hover {
        background-color: var(--cm-row-hover) !important;
    }

    .cm-results-card .cm-detail-table thead th {
        background: #f1f5f9;
        font-size: 0.75rem;
        text-transform: uppercase;
        color: #475569;
    }

    @@media (max-width: 768px) {
        .block-content { padding-left: 20px; }
        .category-content { padding-left: 20px; }
    }

    @@media (max-width: 576px) {
        .block-content { padding-left: 15px; }
        .category-content { padding-left: 15px; }
    }
</style>

<div class="container-fluid cm-detail-page px-2 px-md-2">
    @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @ViewBag.ErrorMessage
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (!string.IsNullOrEmpty(ViewBag.SuccessMessage as string))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @ViewBag.SuccessMessage
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card cm-detail-card shadow-sm border-0">
        <div class="card-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <p class="cm-header-name mb-1 mb-md-0">
                <i class="fas fa-file-invoice-dollar text-muted mr-2" aria-hidden="true"></i>Search bills
                <span class="cm-badge-soft ml-2">Maintenance</span>
            </p>
            <small class="text-muted mb-0 d-none d-md-block">
                <i class="fas fa-mouse-pointer mr-1" aria-hidden="true"></i> Expand project &rarr; block &rarr; category. Double-click a row for bill details.
            </small>
        </div>

        <div class="card-body cm-filter-body border-bottom">
            <form id="searchForm" method="post" action="@Url.Action("SearchBill", "MaintenanceNew")">
                <div class="form-row">
                    <div class="form-group col-md-2 mb-md-0">
                        <label for="project" class="font-weight-bold text-secondary small text-uppercase d-block">Project</label>
                        <select id="project" name="project" class="form-control">
                            <option value="">— Select project —</option>
                            @{
                                var projectList = ViewBag.Projects as List<string> ?? new List<string>();
                                var selectedProject = ViewBag.SelectedProject as string;
                            }
                            @foreach (var proj in projectList)
                            {
                                if (string.Equals(proj, selectedProject, StringComparison.Ordinal))
                                {
                                    <option value="@proj" selected="selected">@proj</option>
                                }
                                else
                                {
                                    <option value="@proj">@proj</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="form-group col-md-2 mb-md-0">
                        <label for="month" class="font-weight-bold text-secondary small text-uppercase d-block">Month</label>
                        <select id="month" name="month" class="form-control">
                            <option value="">-- Choose Month --</option>
                            @foreach (var monthName in System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames.Take(12))
                            {
                                <option value="@monthName" selected="@(monthName == ViewBag.SelectedMonth ? "selected" : null)">
                                    @monthName
                                </option>
                            }
                        </select>
                    </div>
                    <div class="form-group col-md-2 mb-md-0">
                        <label for="year" class="font-weight-bold text-secondary small text-uppercase d-block">Year</label>
                        <select id="year" name="year" class="form-control">
                            <option value="">-- Choose Year --</option>
                            @for (int i = DateTime.Now.Year; i >= DateTime.Now.Year - 10; i--)
                            {
                                <option value="@i" selected="@(i.ToString() == ViewBag.SelectedYear ? "selected" : null)">
                                    @i
                                </option>
                            }
                        </select>
                    </div>
                    <div class="form-group col-md-2 mb-md-0">
                        <label for="btno" class="font-weight-bold text-secondary small text-uppercase d-block">BT No</label>
                        <input type="text" id="btno" name="btno" class="form-control" placeholder="Enter BT No" value="@ViewBag.SelectedBtNo" autocomplete="off" />
                    </div>
                    <div class="form-group col-md-4 mb-0 d-flex align-items-end">
                        <div class="w-100 d-flex">
                            <button type="submit" class="btn btn-primary flex-fill mr-2">
                                <i class="fas fa-search mr-1" aria-hidden="true"></i>Search
                            </button>
                            <button id="PrintRecordsButton" type="button" class="btn btn-outline-secondary flex-fill">
                                <i class="fas fa-print mr-1" aria-hidden="true"></i>Print bill
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        @if (ViewBag.SearchResultCount != null)
        {
            <div class="cm-search-summary text-secondary">
                @{
                    var total = Convert.ToInt32(ViewBag.SearchResultCount);
                    var sm = ViewBag.SelectedMonth as string;
                    var sy = ViewBag.SelectedYear as string;
                    var sbt = ViewBag.SelectedBtNo as string;
                }
                <strong class="text-dark">@total.ToString("N0")</strong> record@(total == 1 ? "" : "s") found
                @if (!string.IsNullOrEmpty(sm) && !string.IsNullOrEmpty(sy))
                {
                    <span> for billing period <strong>@sm</strong> <strong>@sy</strong></span>
                }
                @if (!string.IsNullOrEmpty(sbt))
                {
                    <span> (BT No <strong>@sbt</strong>)</span>
                }
                @{
                    var sp = ViewBag.SelectedProject as string;
                }
                @if (!string.IsNullOrWhiteSpace(sp))
                {
                    <span> · Project <strong>@sp</strong></span>
                }
            </div>
        }

        <div class="card-body p-0">
            <div class="table-responsive cm-table-wrap mx-2 my-2 mb-0">
                <table id="maintenanceTable" class="cm-detail-table cm-search-bill-table mb-0">
                    <thead>
                        <tr>
                            <th style="width:50px;"></th>
                            <th style="width:100px;">
                                <input type="checkbox" id="selectAll" title="Select All Records" />
                            </th>
                            <th data-sort="Btno" class="sort-icon" style="width:200px;">BT No</th>
                            <th data-sort="BillingMonth" class="sort-icon" style="width:200px;">Month</th>
                            <th data-sort="BillingYear" class="sort-icon" style="width:150px;">Year</th>
                            <th data-sort="Category" class="sort-icon" style="width:250px;">Category</th>
                            <th data-sort="CustomerName" class="sort-icon" style="width:300px;">Name</th>
                            <th style="width:150px;">Charges</th>
                            <th style="width:150px;">Arrears</th>
                            <th style="width:150px;">Bill total</th>
                            <th data-sort="PaymentStatus" class="sort-icon" style="width:150px;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var projectGroup in groupedByProject)
                        {
                            var projectId = "project-" + projectGroup.Project?.Replace(" ", "-");
                            <tr class="project-header" data-project="@projectId">
                                <td>
                                    <i class="fas fa-chevron-right toggle-icon"></i>
                                </td>
                                <td colspan="10">
                                    Project: @projectGroup.Project
                                </td>
                            </tr>
                            <tr class="project-content" data-parent="@projectId" style="display:none;">
                                <td colspan="11" style="padding:0;">
                                    <div class="project-blocks">
                                        @foreach (var blockGroup in projectGroup.Blocks)
                                        {
                                            var blockId = $"{projectId}-block-{blockGroup.Key?.Replace(" ", "-")}";
                                            <table class="nested-table" style="width:100%; margin-bottom:0;">
                                                <tr class="block-header" data-block="@blockId">
                                                    <td style="width:50px;">
                                                        <i class="fas fa-chevron-right toggle-icon"></i>
                                                    </td>
                                                    <td colspan="10">
                                                        <strong>Block:</strong> @blockGroup.Key
                                                        <span class="text-muted font-weight-normal ml-2">(@blockGroup.Count())</span>
                                                    </td>
                                                </tr>
                                            </table>
                                            <div class="block-content" id="@blockId" style="display:none;">
                                                <table class="nested-table" style="width:100%; margin-bottom:0;">
                                                    @foreach (var categoryGroup in blockGroup.GroupBy(b => b.Category).OrderBy(g => g.Key))
                                                    {
                                                        var categoryId = $"{blockId}-category-{categoryGroup.Key?.Replace(" ", "-")}";
                                                        <tr class="category-header" data-category="@categoryId">
                                                            <td style="width:50px;">
                                                                <i class="fas fa-chevron-right toggle-icon"></i>
                                                            </td>
                                                            <td colspan="10">
                                                                Category: @categoryGroup.Key
                                                            </td>
                                                        </tr>
                                                        <tr class="category-content" data-parent="@categoryId" style="display:none;">
                                                            <td colspan="11" style="padding:0;">
                                                                <table class="nested-table" style="width:100%; margin-bottom:0;">
                                                                    @foreach (var bill in categoryGroup)
                                                                    {
                                                                        <tr class="customer-row" ondblclick="window.location.href='@Url.Action("Details", "MaintenanceNew", new { id = bill.Uid })'" style="cursor: pointer;">
                                                                            <td style="width:50px;"></td>
                                                                            <td style="width:100px;">
                                                                                <input type="checkbox" class="record-checkbox" value="@bill.Uid"
                                                                                       data-btno="@bill.Btno"
                                                                                       data-month="@bill.BillingMonth"
                                                                                       data-year="@bill.BillingYear"
                                                                                       onclick="event.stopPropagation();" />
                                                                            </td>
                                                                            <td style="width:200px;">@bill.Btno</td>
                                                                            <td style="width:200px;">@bill.BillingMonth</td>
                                                                            <td style="width:150px;">@bill.BillingYear</td>
                                                                            <td style="width:250px;">@bill.Category</td>
                                                                            <td style="width:300px;">@bill.CustomerName</td>
                                                                            <td style="width:150px;">@bill.MaintCharges?.ToString("N0")</td>
                                                                            <td style="width:150px;">@bill.Arrears?.ToString("N0")</td>
                                                                            <td style="width:150px;">@bill.BillAmountInDueDate?.ToString("N0")</td>
                                                                            <td style="width:150px;">@bill.PaymentStatus</td>
                                                                        </tr>
                                                                    }
                                                                </table>
                                                            </td>
                                                        </tr>
                                                    }
                                                </table>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="resultsContainer" class="card cm-detail-card shadow-sm border-0 cm-results-card" style="display:none;">
        <div class="card-header">
            <p class="cm-header-name mb-0" style="font-size:0.95rem;">
                <i class="fas fa-list-alt text-muted mr-2" aria-hidden="true"></i>Bill generation results
            </p>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive cm-table-wrap mx-2 my-2 mb-2">
                <table id="resultsTable" class="cm-detail-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Result</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var savedSearch = sessionStorage.getItem('maintenanceSearchState');
            var isPost = "@Context.Request.Method" === "POST";

            if (savedSearch && !isPost) {
                var state = JSON.parse(savedSearch);
                $('#month').val(state.month);
                $('#year').val(state.year);
                $('#btno').val(state.btno);
                if (state.project) {
                    $('#project').val(state.project);
                }

                if (state.month && state.year || state.btno || state.project) {
                    $('#searchForm').submit();
                }
            }

            $('#searchForm').on('submit', function() {
                var state = {
                    month: $('#month').val(),
                    year: $('#year').val(),
                    btno: $('#btno').val(),
                    project: $('#project').val()
                };
                sessionStorage.setItem('maintenanceSearchState', JSON.stringify(state));
            });

            $('.project-header').click(function () {
                var projectId = $(this).data('project');
                var icon = $(this).find('.toggle-icon');
                var content = $('tr[data-parent="' + projectId + '"]');
                icon.toggleClass('rotate-icon');
                content.toggle();
                if (!content.is(':visible')) {
                    content.find('.block-content, .category-content').hide();
                    content.find('.block-header .toggle-icon, .category-header .toggle-icon').removeClass('rotate-icon');
                }
            });
            $('.block-header').click(function (e) {
                e.stopPropagation();
                var blockId = $(this).data('block');
                var icon = $(this).find('.toggle-icon');
                var content = $('#' + blockId);
                icon.toggleClass('rotate-icon');
                content.toggle();
            });
            $('.category-header').click(function (e) {
                e.stopPropagation();
                var categoryId = $(this).data('category');
                var icon = $(this).find('.toggle-icon');
                var content = $('tr[data-parent="' + categoryId + '"]');
                icon.toggleClass('rotate-icon');
                content.toggle();
            });

            $('#selectAll').change(function () {
                $('.record-checkbox:visible').prop('checked', $(this).prop('checked'));
                updateSelectAllState();
            });
            $('.record-checkbox').change(function () {
                updateSelectAllState();
            });
            function updateSelectAllState() {
                var totalVisible = $('.record-checkbox:visible').length;
                var totalChecked = $('.record-checkbox:visible:checked').length;
                $('#selectAll').prop({
                    checked: totalVisible === totalChecked && totalVisible > 0,
                    indeterminate: totalChecked > 0 && totalChecked < totalVisible
                });
            }

            $('#PrintRecordsButton').on('click', function () {
            var selected = $('.record-checkbox:checked');
            if (selected.length === 0) {
                alert("Please select at least one record to print.");
                return;
            }

            var months = [];
            var years = [];
            var btnos = [];

            selected.each(function () {
                var btno = $(this).data('btno');
                var month = $(this).data('month');
                var year = $(this).data('year');

                if (!months.includes(month)) months.push(month);
                if (!years.includes(year)) years.push(year);
                btnos.push(btno);
            });

            console.log("Months List:", months);
            console.log("Years List:", years);
            console.log("BTNos List:", btnos);

            var params = [];

            selected.each(function() {
                var month = $(this).data('month');
                params.push(`BillingMonths=${encodeURIComponent(month)}`);
            });

            selected.each(function() {
                var year = $(this).data('year');
                params.push(`BillingYears=${encodeURIComponent(year)}`);
            });

            selected.each(function() {
                var btno = $(this).data('btno');
                params.push(`BTNo=${encodeURIComponent(btno)}`);
            });

            var apiUrl = "http://172.20.228.2:81/api/SSQCursorMaintenance/GetMBill?" +
                         params.join('&');

            console.log("API URL (List format):", apiUrl);

            $('#loadingOverlay').show();
            $.ajax({
                url: apiUrl,
                method: 'GET',
                xhrFields: { responseType: 'blob' },
                success: function (data) {
                    $('#loadingOverlay').hide();
                    var blob = new Blob([data], { type: 'application/pdf' });
                    var blobUrl = URL.createObjectURL(blob);
                    window.open(blobUrl, '_blank');
                },
                error: function (xhr) {
                    $('#loadingOverlay').hide();
                    alert('Error: ' + (xhr.responseText || 'Server error'));
                }
            });

            });

        });
    </script>
}
