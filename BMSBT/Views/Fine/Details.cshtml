
@model BMSBT.Models.Fine

@{
    ViewData["Title"] = "Fine Details";
    Layout = "~/Views/Shared/_LayoutFine.cshtml";
    ArgumentNullException.ThrowIfNull(Model);
}

<style>
    .cm-detail-page {
        --cm-surface: #ffffff;
        --cm-heading: #0f172a;
        --cm-border: #e2e8f0;
        --cm-row-odd: #fafbfc;
        --cm-row-even: #ffffff;
        --cm-row-hover: #eef6ff;
        font-size: 0.9375rem;
        line-height: 1.45;
        color: #334155;
        padding-top: 0.35rem;
        padding-bottom: 1rem;
    }

    .cm-detail-card {
        background: var(--cm-surface);
        border: 1px solid var(--cm-border);
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        margin-bottom: 0.75rem;
    }

    .cm-detail-card .card-header {
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        border-bottom: 1px solid var(--cm-border);
        padding: 0.5rem 1rem;
    }

    .cm-detail-card .card-header .cm-header-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--cm-heading);
        margin: 0;
    }

    .cm-badge-soft {
        display: inline-block;
        padding: 0.12rem 0.45rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #e8f1ff;
        color: #1e40af;
        vertical-align: middle;
    }

    .cm-table-wrap {
        border-radius: 6px;
        border: 1px solid var(--cm-border);
        overflow: hidden;
        margin: 0.5rem 0.75rem 0.75rem;
    }

    .cm-detail-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
    }

    .cm-detail-table tbody th {
        background: #f8fafc;
        color: #475569;
        font-weight: 600;
        font-size: 0.8125rem;
        padding: 0.55rem 0.75rem;
        border-bottom: 1px solid var(--cm-border);
        width: 18%;
        vertical-align: middle;
        text-align: left;
    }

    .cm-detail-table tbody td {
        padding: 0.55rem 0.75rem;
        border-bottom: 1px solid var(--cm-border);
        vertical-align: middle;
        background: var(--cm-row-even);
        text-align: left;
    }

    .cm-detail-table tbody tr:nth-child(even) td {
        background: var(--cm-row-odd);
    }

    .cm-detail-table tbody tr:nth-child(even) th {
        background: #f1f5f9;
    }

    .cm-detail-table tbody tr:hover td,
    .cm-detail-table tbody tr:hover th {
        background: var(--cm-row-hover) !important;
    }

    .cm-detail-table tbody tr:last-child th,
    .cm-detail-table tbody tr:last-child td {
        border-bottom: none;
    }

    .cm-card-footer-actions {
        background: #f8fafc;
        border-top: 1px solid var(--cm-border);
        padding: 0.65rem 1rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
    }

    .cm-card-footer-actions .btn-group-actions .btn {
        border-radius: 6px;
        font-weight: 500;
        font-size: 0.875rem;
        padding: 0.4rem 0.75rem;
        display: inline-flex;
        align-items: center;
        margin-left: 0.25rem;
        margin-bottom: 0.25rem;
    }

    .cm-card-footer-actions .btn-group-actions .btn i {
        font-size: 0.9rem;
    }
</style>

<div class="container-fluid cm-detail-page px-2 px-md-2">
    <div class="card cm-detail-card shadow-sm border-0">
        <div class="card-header">
            <p class="cm-header-name">
                @(string.IsNullOrWhiteSpace(Model.CustomerName) ? "Fine Detail" : Model.CustomerName)
                @if (!string.IsNullOrWhiteSpace(Model.BTNo))
                {
                    <span class="cm-badge-soft ml-2">BTNo @Model.BTNo</span>
                }
                else
                {
                    <span class="cm-badge-soft ml-2">Fine ID @Model.FineID</span>
                }
            </p>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive cm-table-wrap">
                <table class="cm-detail-table mb-0">
                    <tbody>
                        <tr>
                            <th scope="row"><i class="fas fa-barcode text-muted mr-1" aria-hidden="true"></i>BT No</th>
                            <td>@Model.BTNo</td>
                            <th scope="row"><i class="fas fa-user text-muted mr-1" aria-hidden="true"></i>Customer Name</th>
                            <td>@Model.CustomerName</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-building text-muted mr-1" aria-hidden="true"></i>Project</th>
                            <td>@Model.ProjectName</td>
                            <th scope="row"><i class="fas fa-th-large text-muted mr-1" aria-hidden="true"></i>Block</th>
                            <td>@Model.Block</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-map-marker-alt text-muted mr-1" aria-hidden="true"></i>Sector</th>
                            <td>@Model.Sector</td>
                            <th scope="row"><i class="fas fa-calendar-alt text-muted mr-1" aria-hidden="true"></i>Fine Month</th>
                            <td>@Model.FineMonth</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="far fa-calendar text-muted mr-1" aria-hidden="true"></i>Fine Year</th>
                            <td>@Model.FineYear</td>
                            <th scope="row"><i class="fas fa-calendar-check text-muted mr-1" aria-hidden="true"></i>Fine Date</th>
                            <td>@Model.DateFine.ToString("yyyy-MM-dd")</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-sitemap text-muted mr-1" aria-hidden="true"></i>Department</th>
                            <td>@Model.Department</td>
                            <th scope="row"><i class="fas fa-tag text-muted mr-1" aria-hidden="true"></i>Fine Type</th>
                            <td>@Model.FineType</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-cogs text-muted mr-1" aria-hidden="true"></i>Fine Service</th>
                            <td>@Model.FineService</td>
                            <th scope="row"><i class="fas fa-layer-group text-muted mr-1" aria-hidden="true"></i>Fine Category</th>
                            <td>@Model.FineCategory</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-money-bill-wave text-muted mr-1" aria-hidden="true"></i>Fine Amount</th>
                            <td>@Model.FineAmount</td>
                            <th scope="row"><i class="fas fa-minus-circle text-muted mr-1" aria-hidden="true"></i>Waived Amount</th>
                            <td>@Model.WaivedAmount</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-sliders-h text-muted mr-1" aria-hidden="true"></i>Adjustment Amount</th>
                            <td>@Model.AdjustmentAmount</td>
                            <th scope="row"><i class="fas fa-file-invoice-dollar text-muted mr-1" aria-hidden="true"></i>Fine To Charge</th>
                            <td>@Model.FineToCharge</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-user-edit text-muted mr-1" aria-hidden="true"></i>Fine Entered By</th>
                            <td>@Model.FineEnteredBy</td>
                            <th scope="row"><i class="fas fa-clock text-muted mr-1" aria-hidden="true"></i>Fine Enter Date</th>
                            <td>@Model.FineEnterDate.ToString("yyyy-MM-dd")</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-comment-dots text-muted mr-1" aria-hidden="true"></i>Comments</th>
                            <td colspan="3">@Model.Comments</td>
                        </tr>
                        <tr>
                            <th scope="row"><i class="fas fa-history text-muted mr-1" aria-hidden="true"></i>History</th>
                            <td colspan="3">@Model.History</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="cm-card-footer-actions">
            <small class="text-muted mb-0 d-none d-sm-block pr-2">
                <i class="far fa-eye mr-1" aria-hidden="true"></i> Read-only record view.
            </small>
            <div class="btn-group-actions btn-group flex-wrap justify-content-end" role="group" aria-label="Fine detail actions">
                <a asp-action="Edit" asp-route-id="@Model.FineID" class="btn btn-primary">
                    <i class="fas fa-edit" aria-hidden="true"></i><span class="d-none d-sm-inline"> Edit</span>
                </a>
                <a asp-action="Index" class="btn btn-outline-dark">
                    <i class="fas fa-arrow-left" aria-hidden="true"></i><span class="d-none d-sm-inline"> List</span>
                </a>
            </div>
        </div>
    </div>
</div>
