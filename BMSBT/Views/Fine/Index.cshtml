@model List<BMSBT.Models.Fine>

@{
    ViewData["Title"] = "Fine Records";
    Layout = "~/Views/Shared/_LayoutFine.cshtml";

    var queryMonth = Context.Request.Query["FineMonth"].ToString();
    var queryYear = Context.Request.Query["FineYear"].ToString();
    var queryBtNo = Context.Request.Query["BTNo"].ToString();
    var queryService = Context.Request.Query["FineService"].ToString();
    var hasFilter = Context.Request.Query.Any(q => !string.IsNullOrEmpty(q.Value.ToString()));
    var fines = Model ?? new List<BMSBT.Models.Fine>();
}

<style>
    .cm-detail-page {
        --cm-surface: #ffffff;
        --cm-heading: #0f172a;
        --cm-border: #e2e8f0;
        --cm-row-odd: #fafbfc;
        --cm-row-even: #ffffff;
        --cm-row-hover: #eef6ff;
        font-size: 0.9375rem;
        line-height: 1.45;
        color: #334155;
        padding-top: 0.35rem;
        padding-bottom: 1rem;
    }

    .cm-detail-card {
        background: var(--cm-surface);
        border: 1px solid var(--cm-border);
        border-radius: 10px;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.06);
        overflow: hidden;
        margin-bottom: 0.75rem;
    }

    .cm-detail-card .card-header {
        background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
        border-bottom: 1px solid var(--cm-border);
        padding: 0.5rem 1rem;
    }

    .cm-detail-card .card-header .cm-header-name {
        font-size: 1rem;
        font-weight: 600;
        color: var(--cm-heading);
        margin: 0;
    }

    .cm-badge-soft {
        display: inline-block;
        padding: 0.12rem 0.45rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: 600;
        background: #e8f1ff;
        color: #1e40af;
        vertical-align: middle;
    }

    .cm-filter-body {
        padding: 1rem 1.25rem;
    }

    .cm-filter-body .form-control {
        border-radius: 6px;
        font-size: 0.875rem;
    }

    .cm-filter-body .btn {
        border-radius: 6px;
        font-weight: 500;
    }

    .cm-table-wrap {
        border-radius: 6px;
        border: 1px solid var(--cm-border);
        overflow: hidden;
        margin: 0.5rem 0.75rem 0.75rem;
    }

    .cm-fine-table {
        width: 100%;
        margin-bottom: 0;
        border-collapse: collapse;
    }

    .cm-fine-table thead th {
        background: #f1f5f9;
        color: #475569;
        font-weight: 600;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        padding: 0.65rem 0.5rem;
        border-bottom: 1px solid var(--cm-border);
        vertical-align: middle;
        border-top: none;
    }

    .cm-fine-table tbody td {
        padding: 0.55rem 0.5rem;
        border-bottom: 1px solid var(--cm-border);
        vertical-align: middle;
        font-size: 0.875rem;
    }

    .cm-fine-table tbody tr:nth-child(even) {
        background: var(--cm-row-odd);
    }

    .cm-fine-table tbody tr:hover {
        background: var(--cm-row-hover) !important;
    }

    .cm-fine-table tbody tr:last-child td {
        border-bottom: none;
    }
</style>

<div class="container-fluid cm-detail-page px-2 px-md-2">
    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible fade show mb-2" role="alert">
            @successMsg
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="card cm-detail-card shadow-sm border-0">
        <div class="card-header">
            <p class="cm-header-name mb-0">
                <i class="fas fa-money-bill-wave mr-1 text-muted" aria-hidden="true"></i> Fine records
                <span class="cm-badge-soft ml-2">@fines.Count record(s)</span>
            </p>
        </div>

        <div class="card-body cm-filter-body border-bottom-0">
            <form method="get" class="mb-0">
                <div class="form-row align-items-end">
                    <div class="form-group col-md-2 mb-2 mb-md-0">
                        <label class="font-weight-bold small text-muted mb-1" for="FineMonth">Month</label>
                        <select id="FineMonth" name="FineMonth" class="form-control">
                            <option value="">-- Month --</option>
                            @{
                                var months = System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.MonthNames;
                                for (int i = 0; i < 12; i++)
                                {
                                    var month = months[i];
                                    if (!string.IsNullOrEmpty(month))
                                    {
                                        if (queryMonth == month)
                                        {
                                            <option value="@month" selected="selected">@month</option>
                                        }
                                        else
                                        {
                                            <option value="@month">@month</option>
                                        }
                                    }
                                }
                            }
                        </select>
                    </div>

                    <div class="form-group col-md-2 mb-2 mb-md-0">
                        <label class="font-weight-bold small text-muted mb-1" for="FineYear">Year</label>
                        <select id="FineYear" name="FineYear" class="form-control">
                            <option value="">-- Year --</option>
                            @if (queryYear == "2027")
                            {
                                <option value="2027" selected="selected">2027</option>
                            }
                            else
                            {
                                <option value="2027">2027</option>
                            }
                            @if (queryYear == "2026")
                            {
                                <option value="2026" selected="selected">2026</option>
                            }
                            else
                            {
                                <option value="2026">2026</option>
                            }
                            @if (queryYear == "2025")
                            {
                                <option value="2025" selected="selected">2025</option>
                            }
                            else
                            {
                                <option value="2025">2025</option>
                            }
                        </select>
                    </div>

                    <div class="form-group col-md-2 mb-2 mb-md-0">
                        <label class="font-weight-bold small text-muted mb-1" for="BTNo">BT No</label>
                        <input id="BTNo" type="text" name="BTNo" class="form-control" value="@queryBtNo" placeholder="BT No" />
                    </div>

                    <div class="form-group col-md-3 mb-2 mb-md-0">
                        <label class="font-weight-bold small text-muted mb-1" for="FineService">Fine Service</label>
                        <select id="FineService" name="FineService" class="form-control">
                            <option value="">-- Fine Service --</option>
                            @if (queryService == "Electricity")
                            {
                                <option value="Electricity" selected="selected">Electricity</option>
                            }
                            else
                            {
                                <option value="Electricity">Electricity</option>
                            }
                            @if (queryService == "Maintenance")
                            {
                                <option value="Maintenance" selected="selected">Maintenance</option>
                            }
                            else
                            {
                                <option value="Maintenance">Maintenance</option>
                            }
                        </select>
                    </div>

                    <div class="form-group col-md-3 mb-0 d-flex flex-wrap align-items-end">
                        <button type="submit" class="btn btn-primary mr-2 mb-2 mb-md-0">
                            <i class="fas fa-search mr-1" aria-hidden="true"></i> Search
                        </button>
                        <a href="@Url.Action("Index", "Fine")" class="btn btn-outline-secondary mb-2 mb-md-0">Reset</a>
                    </div>
                </div>
            </form>
        </div>

        @if (fines.Any())
        {
            <div class="card-body p-0 border-top">
                <div class="table-responsive cm-table-wrap mx-md-2">
                    <table class="table table-sm mb-0 cm-fine-table">
                        <thead>
                            <tr>
                                <th>BT No</th>
                                <th>Customer Name</th>
                                <th>Project</th>
                                <th>Month/Year</th>
                                <th>Service</th>
                                <th>Amount</th>
                                <th>Fine By</th>
                                <th>Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var fine in fines)
                            {
                                <tr ondblclick="openDetails(@fine.FineID)" data-id="@fine.FineID" style="cursor: pointer;">
                                    <td>@fine.BTNo</td>
                                    <td>@fine.CustomerName</td>
                                    <td>@fine.ProjectName</td>
                                    <td>@fine.FineMonth / @fine.FineYear</td>
                                    <td>@fine.FineService</td>
                                    <td>@fine.FineToCharge</td>
                                    <td>@fine.FineEnteredBy</td>
                                    <td>@fine.FineEnterDate.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@fine.FineID" class="btn btn-sm btn-outline-secondary">View</a>
                                        <a asp-action="Edit" asp-route-id="@fine.FineID" class="btn btn-sm btn-outline-primary">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (hasFilter)
        {
            <div class="card-body pt-0">
                <div class="alert alert-info mt-2 mb-0">
                    <strong>No records found</strong> for the selected criteria.
                </div>
            </div>
        }
        else
        {
            <div class="card-body pt-0">
                <div class="alert alert-info mt-2 mb-0">
                    <strong>Please select search criteria</strong> to view fine records.
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function openDetails(fineId) {
            if (!fineId) return;
            window.location.href = '/Fine/Details/' + fineId;
        }
    </script>
}

